# PropOS Environment Variables
# Copy to .env and fill in real values. Never commit .env to git.

# ── LLM Providers ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
GROQ_API_KEY=gsk_...

# ── Singapore Data APIs ────────────────────────────────────────────────────
# URA: Register at https://www.ura.gov.sg/maps/api/reg.html
URA_ACCESS_KEY=

# OneMap: Register at https://www.onemap.gov.sg/apidocs/
ONEMAP_EMAIL=
ONEMAP_PASSWORD=

# data.gov.sg: No key needed for most datasets, but register for higher limits
# https://data.gov.sg/developer

# NewsAPI: https://newsapi.org (free 100 req/day)
NEWSAPI_KEY=

# ── Database ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://propos:password@localhost:5432/propos
# Or SQLite for local dev:
# DATABASE_URL=sqlite:///./propos.db

# ── Telegram ───────────────────────────────────────────────────────────────
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
# Deal alerts channel (create a channel, make bot admin)
TELEGRAM_DEALS_CHANNEL_ID=

# ── App ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-string
ADMIN_PASSWORD=changeme
LLM_MODE=quality

# ── Optional: Mortgage data scraping ──────────────────────────────────────
# No keys needed — mortgage rates scraped from public bank pages
# DBS: https://www.dbs.com.sg/personal/loans/home-loans/interest-rates
# OCBC: https://www.ocbc.com/personal-banking/loans/home-loan-rates
# UOB: https://www.uob.com.sg/personal/borrow/property-loans/home-loan.page
